{
  "name": "mico",
  "private": true,
  "version": "0.0.0",
  "description": "Mission Control for agentic programming workflows.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev:demo": "vite --config vite.config.ts",
    "build:demo": "vite build --config vite.config.ts",
    "dev:supervisor": "npm run build && node dist/types/packages/supervisor/src/server.js",
    "start:supervisor": "node dist/types/packages/supervisor/src/server.js",
    "smoke:supervisor": "node packages/supervisor/scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0"
  }
}
